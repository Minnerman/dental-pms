# Example only. Do not place real credentials or generated rclone config in Git.
# This file is a placeholder template for a later authorised implementation
# slice. It does not configure rclone by itself.

RCLONE_CONFIG=/path/outside/repo/rclone.conf
RCLONE_REMOTE_NAME=dental_pms_gworkspace
RCLONE_CRYPT_REMOTE_NAME=dental_pms_gworkspace_crypt
BACKUP_FOLDER_LABEL="Dental PMS Production Backups"
BACKUP_SOURCE_ARCHIVE=/path/outside/repo/latest-backup.tar
BACKUP_DESTINATION="dental_pms_gworkspace_crypt:Dental PMS Production Backups/"
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE="daily"

# Credential rules:
# - service-account or OAuth credentials must stay outside Git;
# - generated rclone config must stay outside Git;
# - rclone crypt passwords/salts must stay outside Git;
# - no tokens, DSNs, private URLs, exact private paths, backup contents, raw
#   database dumps, or patient data may be committed.
